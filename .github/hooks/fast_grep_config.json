{
  "searchTools": [
    "list_dir",
    "file_search",
    "grep_search",
    "semantic_search",
    "search",
    "find",
    "ls"
  ],
  "mappings": [
    {
      "virtual": "path",
      "real": ".fast-grep/path",
      "enabled": true
    }
  ],
  "autoRefreshBeforePre": {
    "enabled": true,
    "script": ".github/hooks/scripts/build_fast_grep_links.py",
    "listFile": ".github/hooks/fast_grep_items.txt",
    "clean": true,
    "useMappingsAsDefaultItems": true
  }
}
